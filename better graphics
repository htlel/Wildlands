// ── TILE PALETTE ──
// Each tile: [base, detail, detail2]
const TPAL={
  [T.GRASS]:['#1a7a3a','#156632','#219044'],
  [T.DARKGRASS]:['#145c2c','#0f4a22','#1a6e35'],
  [T.DIRT]:['#7a5230','#634221','#8c6340'],
  [T.WATER]:['#1040b8','#0d35a0','#1a52d0'],
  [T.SHALLOW]:['#1a5acc','#1448a8','#206cd8'],
  [T.STONE]:['#4a5568','#3a4454','#5a6578'],
  [T.SAND]:['#c8941c','#b07e14','#d8a82a'],
  [T.SNOW]:['#d8e8f4','#c0d4e8','#eaf4ff'],
  [T.FLOWER]:['#1a7a3a','#156632','#219044'],
  [T.PATH]:['#9a6e28','#7a5418','#b08038'],
  [T.VOID]:['#000','#000','#000'],
};

function drawTile(tx,ty,sx,sy){
  const t=world[ty]?.[tx]??T.VOID;
  const pal=TPAL[t]||TPAL[T.VOID];
  ctx.fillStyle=pal[0];ctx.fillRect(sx,sy,TILE,TILE);

  // Detail layer
  if(t===T.WATER||t===T.SHALLOW){
    // Animated waves
    const woff=(waterAnim*0.8+tx*3+ty*5)%TILE;
    ctx.fillStyle=pal[2];
    ctx.fillRect(sx,sy+(woff%8),TILE,2);
    ctx.fillStyle=pal[1];
    ctx.fillRect(sx,sy+((woff+12)%TILE),TILE,1);
  } else if(t===T.GRASS||t===T.DARKGRASS){
    // Grass blades pattern
    ctx.fillStyle=pal[1];
    const seed=tx*7+ty*13;
    for(let i=0;i<4;i++){
      const ox=(seed+i*9)%28,oy=(seed+i*7)%24;
      ctx.fillRect(sx+ox,sy+oy,2,4);
    }
    ctx.fillStyle=pal[2];
    const ox2=(seed*3)%26,oy2=(seed*5)%22;
    ctx.fillRect(sx+ox2,sy+oy2,2,3);
  } else if(t===T.STONE){
    // Crack lines
    ctx.fillStyle=pal[1];
    ctx.fillRect(sx+2,sy+6,TILE-4,1);
    ctx.fillRect(sx+8,sy+16,TILE-10,1);
    ctx.fillStyle=pal[2];
    ctx.fillRect(sx+TILE-8,sy+2,1,10);
  } else if(t===T.SNOW){
    ctx.fillStyle=pal[2];
    ctx.fillRect(sx+2,sy+2,TILE-4,4);
    ctx.fillStyle=pal[1];
    ctx.fillRect(sx+6,sy+14,TILE-10,3);
  } else if(t===T.PATH){
    ctx.fillStyle=pal[1];
    ctx.fillRect(sx+2,sy+2,TILE-4,TILE-4);
    ctx.fillStyle=pal[2];
    const ox3=(tx*11+ty*7)%20;
    ctx.fillRect(sx+ox3,sy+4,6,3);
  } else if(t===T.SAND){
    ctx.fillStyle=pal[2];
    const ox4=(tx*5+ty*9)%20;
    ctx.fillRect(sx+ox4,sy+8,8,2);
    ctx.fillRect(sx+(ox4+12)%24,sy+18,6,2);
  } else if(t===T.DIRT){
    ctx.fillStyle=pal[1];
    ctx.fillRect(sx+4,sy+4,TILE-8,TILE-8);
    ctx.fillStyle=pal[2];
    const ox5=(tx*3+ty*11)%18;
    ctx.fillRect(sx+ox5,sy+10,5,5);
  }

  // Flowers
  if(t===T.FLOWER){
    const seed2=tx*17+ty*11;
    ctx.fillStyle=['#ff6688','#ffcc44','#ff88dd','#88ddff'][seed2%4];
    ctx.fillRect(sx+(seed2%20)+2,sy+(seed2*3%18)+2,4,4);
    ctx.fillStyle='#ffee88';ctx.fillRect(sx+(seed2%20)+3,sy+(seed2*3%18)+3,2,2);
  }

  // Shallow water edge shimmer
  if(t===T.SHALLOW){
    ctx.fillStyle='rgba(255,255,255,0.12)';
    ctx.fillRect(sx,sy,TILE,2);
  }

  // Subtle grid
  ctx.fillStyle='rgba(0,0,0,0.05)';
  ctx.fillRect(sx,sy,TILE,1);ctx.fillRect(sx,sy,1,TILE);
}

// ── DRAW TREE ──
function drawTree(d,cx,cy){
  const sx=d.x-cx,sy=d.y-cy;
  if(sx<-50||sx>W+50||sy<-70||sy>H+30)return;
  const sc=d.scale||1;
  const tw=Math.floor(32*sc),th=Math.floor(36*sc);
  const tx=sx+(16-tw/2),ty=sy-th+24;

  // Shadow
  ctx.fillStyle='rgba(0,0,0,0.18)';
  ctx.beginPath();ctx.ellipse(sx+14,sy+26,tw/2,6,0,0,Math.PI*2);ctx.fill();

  // Trunk
  const trunkW=Math.floor(8*sc),trunkH=Math.floor(14*sc);
  const trunkX=sx+(16-trunkW/2);
  ctx.fillStyle='#5c3a1e';ctx.fillRect(trunkX,sy+14,trunkW,trunkH);
  ctx.fillStyle='#7a4f2a';ctx.fillRect(trunkX+1,sy+14,2,trunkH);

  // Foliage layers (back to front)
  const v=d.variant||0;
  const greens=[['#1a6e30','#22883c','#2da050'],['#1a5e28','#1e7230','#27913d'],['#155a25','#1d7030','#258540']];
  const g=greens[v%3];
  // Bottom layer wide
  ctx.fillStyle=g[0];ctx.fillRect(tx-4,ty+th/2,tw+8,th/2);
  // Mid layer
  ctx.fillStyle=g[1];ctx.fillRect(tx,ty+th/4,tw,th*3/4);
  // Top cone
  ctx.fillStyle=g[2];ctx.fillRect(tx+4,ty,tw-8,th/2);
  // Highlight
  ctx.fillStyle='rgba(255,255,255,0.07)';ctx.fillRect(tx+2,ty+2,4,th/3);
}

// ── DRAW ROCK ──
function drawRock(d,cx,cy){
  const sx=d.x-cx,sy=d.y-cy;
  if(sx<-30||sx>W||sy<-30||sy>H)return;
  const r=d.r||6;
  ctx.fillStyle='rgba(0,0,0,0.15)';
  ctx.beginPath();ctx.ellipse(sx+2,sy+r+2,r+2,r*.6,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#555e6a';ctx.beginPath();ctx.ellipse(sx,sy,r,r*.75,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#6b7585';ctx.beginPath();ctx.ellipse(sx-r*.2,sy-r*.2,r*.55,r*.4,-.3,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,255,255,0.1)';ctx.beginPath();ctx.ellipse(sx-r*.25,sy-r*.2,r*.2,r*.15,-.5,0,Math.PI*2);ctx.fill();
}

// ── DRAW PLAYER ──
function drawPlayer(cx,cy){
  const sx=player.x-cx,sy=player.y-cy;
  if(player.invincible>0&&Math.floor(player.invincible/3)%2===0)return;
  const f=player.facing;

  // Shadow
  ctx.fillStyle='rgba(0,0,0,0.22)';
  ctx.beginPath();ctx.ellipse(sx+player.w/2,sy+player.h+3,player.w/2+2,5,0,0,Math.PI*2);ctx.fill();

  // Legs with walk anim
  const legOff=Math.sin(player.walkStep*.25)*3;
  ctx.fillStyle='#3b2460';ctx.fillRect(sx+1,sy+14,5,10+legOff);
  ctx.fillRect(sx+player.w-6,sy+14,5,10-legOff);
  // Boots
  ctx.fillStyle='#1a0e30';
  ctx.fillRect(sx+(f>0?8:0),sy+22,player.w/2+2,4);

  // Body / tunic
  ctx.fillStyle='#6d28d9';ctx.fillRect(sx,sy+6,player.w,10);
  // Belt
  ctx.fillStyle='#7c3aed';ctx.fillRect(sx,sy+6,player.w,2);
  ctx.fillStyle='#5b21b6';ctx.fillRect(sx,sy+14,player.w,2);

  // Cape / shoulder
  ctx.fillStyle='#4c1d95';
  ctx.fillRect(sx+(f>0?-3:player.w-2),sy+6,5,8);

  // Head
  ctx.fillStyle='#fde68a';ctx.fillRect(sx+2,sy,player.w-4,8);
  // Hair
  ctx.fillStyle='#78350f';ctx.fillRect(sx+2,sy-3,player.w-4,5);
  // Eye
  ctx.fillStyle='#1a0a30';
  if(f>0)ctx.fillRect(sx+9,sy+2,2,2);else ctx.fillRect(sx+3,sy+2,2,2);
  // Eye glint
  ctx.fillStyle='rgba(255,255,255,0.6)';
  if(f>0)ctx.fillRect(sx+10,sy+2,1,1);else ctx.fillRect(sx+4,sy+2,1,1);

  // Sword
  if(player.attackTimer>player.attackCooldown-8){
    const ang=player.attackTimer/player.attackCooldown;
    const bx=sx+player.w/2+f*6,by=sy+6;
    ctx.save();ctx.translate(bx,by);ctx.rotate(f*(1.2-ang*1.8));
    ctx.fillStyle='#94a3b8';ctx.fillRect(-2,-18,4,20);
    ctx.fillStyle='#fbbf24';ctx.fillRect(-4,-2,8,4);
    ctx.fillStyle='#cbd5e1';ctx.fillRect(-1,-24,2,8);
    ctx.restore();
  } else {
    // Idle sword at side
    ctx.fillStyle='#94a3b8';ctx.fillRect(sx+(f>0?player.w:-3),sy+6,3,14);
    ctx.fillStyle='#fbbf24';ctx.fillRect(sx+(f>0?player.w-1:-4),sy+8,5,3);
  }
}

// ── DRAW ENEMY ──
function drawEnemy(e,cx,cy){
  if(!e.alive)return;
  const sx=e.x-cx,sy=e.y-cy;
  if(sx<-60||sx>W+60||sy<-60||sy>H+60)return;

  ctx.fillStyle='rgba(0,0,0,0.18)';
  ctx.beginPath();ctx.ellipse(sx+e.w/2,sy+e.h+3,e.w/2+1,4,0,0,Math.PI*2);ctx.fill();

  const fl=e.flashTimer>0;
  const col=fl?'#ffffff':e.color,col2=fl?'#ffffff':e.color2;

  if(e.name==='Slime'){
    // Body
    ctx.fillStyle=col2;ctx.beginPath();ctx.ellipse(sx+e.w/2,sy+e.h/2+2,e.w/2+1,e.h/2+2,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=col;ctx.beginPath();ctx.ellipse(sx+e.w/2,sy+e.h/2,e.w/2,e.h/2,0,0,Math.PI*2);ctx.fill();
    // Shine
    ctx.fillStyle='rgba(255,255,255,0.35)';ctx.beginPath();ctx.ellipse(sx+e.w/2-3,sy+4,4,3,-.5,0,Math.PI*2);ctx.fill();
    // Eyes
    ctx.fillStyle='#000';ctx.fillRect(sx+4,sy+6,3,3);ctx.fillRect(sx+11,sy+6,3,3);
    ctx.fillStyle='rgba(255,255,255,0.6)';ctx.fillRect(sx+5,sy+6,1,1);ctx.fillRect(sx+12,sy+6,1,1);
  } else if(e.name==='Bat'){
    // Wings
    ctx.fillStyle=fl?'#ffffff':'#7c3aed';
    ctx.fillRect(sx-8,sy+2,10,6);ctx.fillRect(sx+e.w-2,sy+2,10,6);
    ctx.fillRect(sx-5,sy+8,8,4);ctx.fillRect(sx+e.w-3,sy+8,8,4);
    // Body
    ctx.fillStyle=col;ctx.fillRect(sx+1,sy+4,e.w-2,e.h-4);
    // Eyes (red)
    ctx.fillStyle=fl?'#ff4444':'#ff0000';ctx.fillRect(sx+3,sy+6,3,3);ctx.fillRect(sx+9,sy+6,3,3);
    ctx.fillStyle='rgba(255,255,255,0.5)';ctx.fillRect(sx+4,sy+6,1,1);
  } else if(e.name==='Wolf'){
    // Body
    ctx.fillStyle=col;ctx.fillRect(sx,sy+8,e.w,e.h-8);
    // Head
    ctx.fillStyle=col2;ctx.fillRect(sx+e.w-6,sy+2,8,10);
    // Snout
    ctx.fillStyle=col;ctx.fillRect(sx+e.w-2,sy+7,6,5);
    ctx.fillStyle='#ffa0a0';ctx.fillRect(sx+e.w+1,sy+9,4,2);
    // Eye
    ctx.fillStyle='#ffcc00';ctx.fillRect(sx+e.w-4,sy+4,2,2);
    // Legs
    ctx.fillStyle=col2;ctx.fillRect(sx,sy+e.h-4,5,6);ctx.fillRect(sx+e.w-5,sy+e.h-4,5,6);
    // Tail
    ctx.fillStyle=col;ctx.fillRect(sx-5,sy+8,6,4);
  } else if(e.name==='Skeleton'){
    // Bones body
    ctx.fillStyle=col;
    ctx.fillRect(sx+2,sy+10,e.w-4,e.h-10);
    ctx.fillStyle=col2;ctx.fillRect(sx+4,sy+12,2,e.h-12);ctx.fillRect(sx+e.w-6,sy+12,2,e.h-12);
    ctx.fillRect(sx+3,sy+16,e.w-6,2);ctx.fillRect(sx+3,sy+22,e.w-6,2);
    // Head
    ctx.fillStyle=col;ctx.fillRect(sx+1,sy,e.w-2,12);
    ctx.fillStyle='#000';ctx.fillRect(sx+3,sy+3,4,4);ctx.fillRect(sx+e.w-7,sy+3,4,4);
    ctx.fillStyle='rgba(255,100,100,0.8)';ctx.fillRect(sx+4,sy+4,2,2);ctx.fillRect(sx+e.w-6,sy+4,2,2);
    // Teeth
    ctx.fillStyle='#ddd';ctx.fillRect(sx+4,sy+9,2,3);ctx.fillRect(sx+7,sy+9,2,3);ctx.fillRect(sx+e.w-7,sy+9,2,3);
  } else {
    // Goblin
    ctx.fillStyle=col;ctx.fillRect(sx,sy+4,e.w,e.h-4);
    // Hat
    ctx.fillStyle=col2;ctx.fillRect(sx+2,sy,e.w-4,6);
    ctx.fillRect(sx+5,sy-4,e.w-10,5);
    // Eyes
    ctx.fillStyle='#ff4400';ctx.fillRect(sx+3,sy+6,3,3);ctx.fillRect(sx+e.w-6,sy+6,3,3);
    ctx.fillStyle='rgba(255,200,0,0.7)';ctx.fillRect(sx+4,sy+7,1,1);
    // Teeth
    ctx.fillStyle='#eee';ctx.fillRect(sx+4,sy+12,2,4);ctx.fillRect(sx+e.w-6,sy+12,2,4);
  }

  // HP bar
  const bw=e.w+10,bh=4,bx=sx-5,by=sy-12;
  ctx.fillStyle='rgba(0,0,0,0.55)';ctx.fillRect(bx,by,bw,bh);
  const ratio=e.hp/e.maxHp;
  ctx.fillStyle=ratio>.6?'#44dd88':ratio>.3?'#ffcc44':'#ff4455';
  ctx.fillRect(bx,by,Math.floor(bw*ratio),bh);
  // HP bar border
  ctx.fillStyle='rgba(255,255,255,0.15)';ctx.fillRect(bx,by,bw,1);
}

// ── DRAW NPC ──
function drawNPC(n,cx,cy){
  const sx=n.x-cx,sy=n.y-cy;
