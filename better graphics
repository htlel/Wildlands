<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wildlands</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323:wght@400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --night:#060412;
  --accent:#b06aff;
  --accent2:#40e0ff;
  --gold:#ffcc44;
  --red:#ff5566;
  --green:#44ffaa;
  --ui-bg:rgba(6,4,18,0.88);
  --ui-border:rgba(176,106,255,0.35);
}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'VT323',monospace;color:#fff;user-select:none}

/* TITLE */
#titleScreen{
  position:fixed;inset:0;z-index:1000;
  background:radial-gradient(ellipse at 50% 55%,#1a0838 0%,#060412 65%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.t-stars{position:absolute;inset:0;pointer-events:none}
.star{position:absolute;background:#fff;border-radius:50%;animation:twinkle var(--d,2s) ease-in-out infinite alternate}
@keyframes twinkle{from{opacity:.15}to{opacity:.9}}

.moon{
  position:absolute;top:8%;right:12%;
  width:72px;height:72px;border-radius:50%;
  background:radial-gradient(circle at 35% 35%,#f5f0e8,#c8bda0);
  box-shadow:0 0 40px rgba(245,240,232,0.3),0 0 80px rgba(245,240,232,0.1);
}
.moon::after{content:'';position:absolute;top:12px;left:18px;width:10px;height:10px;border-radius:50%;background:rgba(0,0,0,0.12)}

.mountain-layer{position:absolute;bottom:0;left:0;right:0}

.logo-wrap{position:relative;z-index:10;text-align:center;margin-bottom:10px}
.game-logo{
  font-family:'Press Start 2P',monospace;
  font-size:clamp(24px,5.5vw,52px);
  color:#fff;
  text-shadow:0 0 30px #b06aff,0 0 60px rgba(176,106,255,.4),0 6px 0 rgba(0,0,0,.8);
  letter-spacing:6px;
  animation:logoFloat 4s ease-in-out infinite;
  display:block;
}
@keyframes logoFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.game-sub{
  font-size:clamp(12px,2.2vw,18px);
  color:rgba(176,106,255,.6);
  letter-spacing:10px;
  margin-top:4px;
  display:block;
}

.start-btn{
  font-family:'Press Start 2P',monospace;
  font-size:clamp(9px,1.6vw,13px);
  padding:14px 28px;
  background:transparent;
  border:2px solid var(--accent);
  color:var(--accent);
  cursor:pointer;
  letter-spacing:3px;
  animation:blink 1.3s step-start infinite;
  clip-path:polygon(8px 0%,calc(100% - 8px) 0%,100% 8px,100% calc(100% - 8px),calc(100% - 8px) 100%,8px 100%,0% calc(100% - 8px),0% 8px);
  margin-top:32px;
  position:relative;z-index:10;
  transition:background .1s,color .1s;
}
.start-btn:hover{background:var(--accent);color:#fff;animation:none}
@keyframes blink{0%,49%{opacity:1}50%,100%{opacity:.25}}

.ctrl-hint{margin-top:24px;font-size:clamp(13px,2vw,17px);color:rgba(255,255,255,.3);letter-spacing:2px;line-height:2.2;text-align:center;z-index:10;position:relative}

/* HUD */
#hud{position:fixed;top:0;left:0;right:0;z-index:50;pointer-events:none;padding:10px 14px;display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
.hud-panel{
  background:var(--ui-bg);
  border:1px solid var(--ui-border);
  padding:8px 12px;
  backdrop-filter:blur(6px);
  clip-path:polygon(6px 0%,calc(100% - 6px) 0%,100% 6px,100% calc(100% - 6px),calc(100% - 6px) 100%,6px 100%,0% calc(100% - 6px),0% 6px);
}
.hud-label{font-size:10px;color:rgba(255,255,255,.35);letter-spacing:3px;margin-bottom:5px}
.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.bar-label{font-size:15px;width:20px;line-height:1}
.bar-track{width:130px;height:9px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);position:relative;overflow:hidden}
.bar-track::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(90deg,transparent 0px,transparent 9px,rgba(0,0,0,.25) 9px,rgba(0,0,0,.25) 10px)}
.bar-fill{height:100%;transition:width .15s}
.bar-val{font-size:14px;color:rgba(255,255,255,.5);min-width:28px}
#hpBar{background:linear-gradient(90deg,#c0392b,#ff5566);box-shadow:0 0 8px rgba(255,85,102,.5)}
#mpBar{background:linear-gradient(90deg,#2468cc,#40e0ff);box-shadow:0 0 8px rgba(64,224,255,.4)}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px 14px;margin-top:5px}
.stat-item{font-size:14px;color:rgba(255,255,255,.55)}
.stat-val{color:var(--gold)}

/* Minimap */
#minimapWrap{position:relative}
#minimapCanvas{display:block;image-rendering:pixelated}
.minimap-border{position:absolute;inset:-1px;border:1px solid var(--ui-border);pointer-events:none}

/* Zone toast */
#zoneToast{
  position:fixed;bottom:90px;left:50%;transform:translateX(-50%);
  font-family:'Press Start 2P',monospace;font-size:11px;
  color:#fff;text-shadow:0 0 8px var(--accent);
  background:var(--ui-bg);border:1px solid var(--ui-border);
  padding:9px 22px;letter-spacing:2px;z-index:50;pointer-events:none;
  opacity:0;transition:opacity .5s;white-space:nowrap;
}
#zoneToast.show{opacity:1}

/* Notifications */
#notif{
  position:fixed;top:76px;left:50%;transform:translateX(-50%);
  font-size:19px;color:var(--gold);
  background:var(--ui-bg);border:1px solid rgba(255,204,68,.35);
  padding:7px 18px;z-index:60;pointer-events:none;
  opacity:0;transition:opacity .3s;white-space:nowrap;letter-spacing:1px;
}

/* Hotbar */
#hotbar{
  position:fixed;bottom:12px;left:50%;transform:translateX(-50%);
  z-index:50;display:flex;gap:5px;
  background:var(--ui-bg);border:1px solid var(--ui-border);
  padding:6px 8px;pointer-events:none;
  clip-path:polygon(6px 0%,calc(100% - 6px) 0%,100% 6px,100% calc(100% - 6px),calc(100% - 6px) 100%,6px 100%,0% calc(100% - 6px),0% 6px);
}
.hotbar-slot{
  width:42px;height:42px;
  border:1px solid rgba(255,255,255,.12);
  background:rgba(255,255,255,.04);
  display:flex;align-items:center;justify-content:center;
  font-size:20px;position:relative;
  transition:border-color .1s,background .1s;
}
.hotbar-slot.active{border-color:var(--accent);background:rgba(176,106,255,.15);box-shadow:0 0 10px rgba(176,106,255,.3),inset 0 0 8px rgba(176,106,255,.1)}
.hk{position:absolute;top:2px;left:4px;font-size:9px;color:rgba(255,255,255,.3);font-family:'Press Start 2P',monospace}

#gameCanvas{display:block;image-rendering:pixelated;image-rendering:crisp-edges}
</style>
</head>
<body>

<div id="titleScreen">
  <div class="t-stars" id="stars"></div>
  <div class="moon"></div>
  <svg class="mountain-layer" viewBox="0 0 1200 320" preserveAspectRatio="xMidYMax meet" style="position:absolute;bottom:0;left:0;width:100%;height:auto">
    <!-- Back mountains -->
    <polygon points="0,320 0,200 80,120 160,200 240,100 320,200 400,80 480,200 560,130 640,200 720,60 800,180 880,100 960,200 1040,110 1120,200 1200,140 1200,320" fill="#110628"/>
    <!-- Snow caps -->
    <polygon points="400,80 430,108 370,108" fill="rgba(255,255,255,0.6)"/>
    <polygon points="720,60 748,88 692,88" fill="rgba(255,255,255,0.5)"/>
    <polygon points="1040,110 1062,132 1018,132" fill="rgba(255,255,255,0.45)"/>
    <!-- Mid mountains -->
    <polygon points="0,320 0,230 60,170 140,250 200,160 300,250 380,150 460,250 540,180 620,260 700,140 780,240 860,160 940,250 1020,155 1100,240 1200,170 1200,320" fill="#1c0940"/>
    <!-- Near hills -->
    <polygon points="0,320 0,280 100,240 200,280 350,230 500,275 650,235 800,275 950,240 1100,270 1200,250 1200,320" fill="#0e0520"/>
    <!-- Ground -->
    <rect x="0" y="300" width="1200" height="20" fill="#120828"/>
    <!-- Trees silhouette -->
    <g fill="#0a0318">
      <rect x="60" y="270" width="8" height="30"/>
      <polygon points="52,275 64,240 76,275"/>
      <polygon points="54,265 64,235 74,265"/>
      <rect x="180" y="265" width="8" height="35"/>
      <polygon points="172,270 184,232 196,270"/>
      <polygon points="174,258 184,226 194,258"/>
      <rect x="900" y="268" width="8" height="32"/>
      <polygon points="892,273 904,237 916,273"/>
      <polygon points="894,261 904,231 914,261"/>
      <rect x="1050" y="272" width="8" height="28"/>
      <polygon points="1042,277 1054,243 1066,277"/>
      <polygon points="1044,265 1054,237 1064,265"/>
    </g>
  </svg>

  <div class="logo-wrap">
    <span class="game-logo">WILDLANDS</span>
    <span class="game-sub">OPEN WORLD</span>
  </div>
  <button class="start-btn" onclick="startGame()">▶ PRESS TO START</button>
  <div class="ctrl-hint">
    WASD / ARROWS — MOVE &nbsp;|&nbsp; SPACE — ATTACK<br>
    E — INTERACT &nbsp;|&nbsp; 1-4 — HOTBAR
  </div>
</div>

<!-- HUD -->
<div id="hud" style="display:none">
  <div class="hud-panel">
    <div class="hud-label">HERO</div>
    <div class="bar-row">
      <span class="bar-label">❤</span>
      <div class="bar-track"><div class="bar-fill" id="hpBar" style="width:100%"></div></div>
      <span class="bar-val" id="hpText">100</span>
    </div>
    <div class="bar-row">
      <span class="bar-label">✦</span>
      <div class="bar-track"><div class="bar-fill" id="mpBar" style="width:100%"></div></div>
      <span class="bar-val" id="mpText">100</span>
    </div>
    <div class="stat-grid">
      <div class="stat-item">LVL <span class="stat-val" id="sLvl">1</span></div>
      <div class="stat-item">EXP <span class="stat-val" id="sExp">0</span></div>
      <div class="stat-item">💰 <span class="stat-val" id="sGold">0</span></div>
      <div class="stat-item">☠ <span class="stat-val" id="sKills">0</span></div>
    </div>
  </div>
  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px">
    <div class="hud-panel" style="padding:5px">
      <div class="hud-label" style="text-align:center">MAP</div>
      <div id="minimapWrap"><canvas id="minimapCanvas" width="128" height="96"></canvas><div class="minimap-border"></div></div>
    </div>
    <div class="hud-panel" style="font-size:13px;letter-spacing:1px" id="zoneHud">ZONE: —</div>
  </div>
</div>

<div id="zoneToast"></div>
<div id="notif"></div>

<div id="hotbar" style="display:none">
  <div class="hotbar-slot active"><span class="hk">1</span>⚔</div>
  <div class="hotbar-slot"><span class="hk">2</span>🏹</div>
  <div class="hotbar-slot"><span class="hk">3</span>🧪</div>
  <div class="hotbar-slot"><span class="hk">4</span>🛡</div>
</div>

<canvas id="gameCanvas"></canvas>

<script>
// ── Stars on title ──
(function(){
  const c=document.getElementById('stars');
  for(let i=0;i<120;i++){
    const s=document.createElement('div');
    s.className='star';
    const sz=Math.random()<0.15?2:1;
    s.style.cssText=`width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${1.5+Math.random()*3}s;animation-delay:${Math.random()*3}s`;
    c.appendChild(s);
  }
})();

// ── Engine ──
const canvas=document.getElementById('gameCanvas');
const ctx=canvas.getContext('2d');
let W,H;
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
resize();window.addEventListener('resize',resize);

const TILE=32,WW=200,WH=150;
const WPX=WW*TILE,HPX=WH*TILE;
const T={VOID:0,GRASS:1,DIRT:2,WATER:3,STONE:4,SAND:5,SNOW:6,DARKGRASS:7,FLOWER:8,PATH:9,SHALLOW:10};

let world=[],decorations=[],enemies=[],npcs=[],chests=[],particles=[],dmgTexts=[];
let camera={x:0,y:0},gameState='title',dialogBox=null,activeSlot=0;
let notifQueue=[],notifTimer=0,currentZone='';
let waterAnim=0;

// Noise
function noise(x,y,s=0){const n=Math.sin(x*127.1+y*311.7+s*43.5)*43758.5453;return n-Math.floor(n)}
function snoise(x,y,s=0){let v=0,a=1,f=1,m=0;for(let i=0;i<5;i++){v+=noise(x*f/30,y*f/30,s+i*7)*a;m+=a;a*=.5;f*=2}return v/m}

function generateWorld(){
  world=[];decorations=[];enemies=[];npcs=[];chests=[];
  for(let y=0;y<WH;y++){
    world[y]=[];
    for(let x=0;x<WW;x++){
      const h=snoise(x,y,0),m=snoise(x,y,99),t=snoise(x,y,55);
      let tile;
      if(h<.22)tile=T.WATER;
      else if(h<.27)tile=T.SHALLOW;
      else if(h<.33)tile=T.SAND;
      else if(h<.42)tile=T.DIRT;
      else if(m>.74)tile=T.STONE;
      else if(h>.82)tile=T.SNOW;
      else if(h>.68)tile=T.STONE;
      else if(t>.6&&h>.45)tile=T.DARKGRASS;
      else if(Math.random()<.04)tile=T.FLOWER;
      else tile=T.GRASS;
      world[y][x]=tile;
    }
  }

  // Villages
  [[40,35],[120,80],[160,120],[30,110],[80,40]].forEach(([vx,vy],vi)=>{
    for(let dy=-6;dy<=6;dy++)for(let dx=-6;dx<=6;dx++){
      const tx=vx+dx,ty=vy+dy;
      if(tx>0&&tx<WW-1&&ty>0&&ty<WH-1&&world[ty][tx]!==T.WATER){
        if(Math.abs(dx)<=1||Math.abs(dy)<=1)world[ty][tx]=T.PATH;
        else if(world[ty][tx]!==T.PATH)world[ty][tx]=T.DIRT;
      }
    }
    const names=['Merchant','Elder','Guard','Traveler','Herbalist'];
    const msgs=['Trade? I have rare wares!','These ruins hold ancient power...','Monsters lurk to the east.','The desert is treacherous.','Drink this potion — it heals!'];
    npcs.push({x:(vx+3)*TILE,y:(vy-1)*TILE,w:14,h:22,color:'#60a5fa',name:names[vi],msg:msgs[vi],dir:1,timer:0,wvx:0});
  });

  // Trees
  for(let y=1;y<WH-1;y++)for(let x=1;x<WW-1;x++){
    const t=world[y][x];
    if((t===T.GRASS||t===T.DARKGRASS)&&Math.random()<.035)
      decorations.push({type:'tree',x:x*TILE,y:y*TILE,variant:Math.floor(Math.random()*3),scale:.8+Math.random()*.4});
  }

  // Rocks
  for(let y=1;y<WH-1;y++)for(let x=1;x<WW-1;x++){
    if(world[y][x]===T.STONE&&Math.random()<.05)
      decorations.push({type:'rock',x:x*TILE+4,y:y*TILE+4,r:4+Math.random()*8});
  }

  // Enemies
  const etypes=[
    {name:'Slime',color:'#33dd66',color2:'#22aa44',hp:20,dmg:5,exp:10,gold:3,w:20,h:16,spd:.6},
    {name:'Bat',color:'#cc88ff',color2:'#9933cc',hp:12,dmg:8,exp:8,gold:2,w:18,h:14,spd:1.1},
    {name:'Goblin',color:'#88cc22',color2:'#557711',hp:35,dmg:12,exp:20,gold:8,w:18,h:24,spd:.8},
    {name:'Wolf',color:'#aabbcc',color2:'#778899',hp:45,dmg:18,exp:30,gold:5,w:22,h:18,spd:1.3},
    {name:'Skeleton',color:'#ddeeff',color2:'#aabbcc',hp:60,dmg:22,exp:40,gold:12,w:16,h:28,spd:.7},
  ];
  for(let i=0;i<120;i++){
    let ex,ey;
    do{ex=Math.floor(Math.random()*WW);ey=Math.floor(Math.random()*WH)}
    while(world[ey]?.[ex]===T.WATER||world[ey]?.[ex]===T.VOID);
    const t={...etypes[Math.floor(Math.random()*etypes.length)]};
    enemies.push({...t,x:ex*TILE,y:ey*TILE,maxHp:t.hp,alive:true,aggro:false,dir:1,flashTimer:0,wvx:0,wvy:0,timer:Math.floor(Math.random()*120)});
  }

  // Chests
  for(let i=0;i<30;i++){
    let cx,cy;
    do{cx=Math.floor(Math.random()*WW);cy=Math.floor(Math.random()*WH)}
    while(world[cy]?.[cx]===T.WATER);
    chests.push({x:cx*TILE+8,y:cy*TILE+8,opened:false});
  }
}

// Player
const player={
  x:40*TILE,y:35*TILE,w:14,h:22,vx:0,vy:0,spd:3,
  hp:100,maxHp:100,mp:100,maxMp:100,
  atk:15,def:2,lvl:1,exp:0,expNext:50,
  gold:0,kills:0,
  attackTimer:0,attackCooldown:18,
  facing:1,animFrame:0,animTimer:0,
  invincible:0,walkStep:0
};

// Input
const keys={};
window.addEventListener('keydown',e=>{
  keys[e.code]=true;
  if(['Space','ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.code))e.preventDefault();
  if(e.code==='Digit1')setSlot(0);if(e.code==='Digit2')setSlot(1);
  if(e.code==='Digit3')setSlot(2);if(e.code==='Digit4')setSlot(3);
  if(e.code==='KeyE'&&gameState==='playing')tryInteract();
  if(e.code==='Space'&&gameState==='playing')tryAttack();
  if(e.code==='Escape')dialogBox=null;
});
window.addEventListener('keyup',e=>{keys[e.code]=false});
function setSlot(i){activeSlot=i;document.querySelectorAll('.hotbar-slot').forEach((s,j)=>s.classList.toggle('active',j===i))}

// Collision
function isSolid(tx,ty){
  if(tx<0||ty<0||tx>=WW||ty>=WH)return true;
  const t=world[ty]?.[tx];return t===T.WATER||t===T.STONE;
}
function isSolidPx(px,py){return isSolid(Math.floor(px/TILE),Math.floor(py/TILE))}
function moveWith(ent,dx,dy){
  const nx=ent.x+dx,ny=ent.y+dy;
  const hw=ent.w/2,b=ent.h-4;
  const bx=!isSolidPx(nx-hw+1,ent.y+b/2)&&!isSolidPx(nx+hw-1,ent.y+b/2)&&!isSolidPx(nx-hw+1,ent.y+ent.h-2)&&!isSolidPx(nx+hw-1,ent.y+ent.h-2);
  const by=!isSolidPx(ent.x-hw+1,ny+b/2)&&!isSolidPx(ent.x+hw-1,ny+b/2)&&!isSolidPx(ent.x-hw+1,ny+ent.h-2)&&!isSolidPx(ent.x+hw-1,ny+ent.h-2);
  if(bx)ent.x=nx;if(by)ent.y=ny;
}

// Attack
function tryAttack(){
  if(player.attackTimer>0)return;
  player.attackTimer=player.attackCooldown;
  const range=44,cx=player.x+player.w/2+player.facing*range,cy=player.y+player.h/2;
  for(let i=0;i<10;i++)particles.push({x:cx+(Math.random()-.5)*20,y:cy+(Math.random()-.5)*20,vx:(Math.random()-.5)*6,vy:(Math.random()-1.5)*4,life:18,maxLife:18,color:Math.random()<.5?'#ffcc44':'#ffaa22',r:2+Math.random()*3,type:'spark'});
  enemies.forEach(e=>{
    if(!e.alive)return;
    const ex=e.x+e.w/2,ey=e.y+e.h/2;
    if(Math.abs(ex-cx)<42&&Math.abs(ey-cy)<38){
      const dmg=player.atk+Math.floor(Math.random()*10);
      e.hp-=dmg;e.flashTimer=10;
      spawnDmg(e.x+e.w/2,e.y-8,dmg,'#ffcc44');
      if(e.hp<=0){
        e.alive=false;player.exp+=e.exp;player.gold+=e.gold;player.kills++;
        checkLvl();notify(`+${e.exp} EXP  +${e.gold}G`);
        for(let i=0;i<14;i++)particles.push({x:e.x+e.w/2,y:e.y+e.h/2,vx:(Math.random()-.5)*7,vy:(Math.random()-1.5)*6,life:30,maxLife:30,color:e.color,r:3+Math.random()*4,type:'burst'});
      }
    }
  });
}

let dmgTexts2=[];
function spawnDmg(x,y,v,col='#fff'){dmgTexts2.push({x,y,vy:-1.8,life:45,maxLife:45,val:v,color:col})}

function checkLvl(){
  if(player.exp>=player.expNext){
    player.lvl++;player.exp-=player.expNext;player.expNext=Math.floor(player.expNext*1.65);
    player.maxHp+=20;player.hp=player.maxHp;player.maxMp+=10;player.mp=player.maxMp;player.atk+=5;
    notify(`⚡ LEVEL UP! Now Lv.${player.lvl}`);
    for(let i=0;i<24;i++)particles.push({x:player.x+player.w/2,y:player.y,vx:(Math.random()-.5)*9,vy:(Math.random()-2)*6,life:45,maxLife:45,color:Math.random()<.5?'#ffcc44':'#b06aff',r:4+Math.random()*4,type:'burst'});
  }
}

function tryInteract(){
  const px=player.x+player.w/2,py=player.y+player.h/2;
  for(const n of npcs){if(Math.abs(n.x+n.w/2-px)<52&&Math.abs(n.y+n.h/2-py)<52){dialogBox={name:n.name,text:n.msg,timer:240};return}}
  for(const ch of chests){
    if(!ch.opened&&Math.abs(ch.x-px)<42&&Math.abs(ch.y-py)<42){
      ch.opened=true;const g=10+Math.floor(Math.random()*60),hp=20+Math.floor(Math.random()*40);
      player.gold+=g;player.hp=Math.min(player.maxHp,player.hp+hp);
      notify(`✦ Chest! +${g}G  +${hp}HP`);
      for(let i=0;i<12;i++)particles.push({x:ch.x,y:ch.y,vx:(Math.random()-.5)*6,vy:(Math.random()-2)*5,life:35,maxLife:35,color:'#ffcc44',r:3+Math.random()*3,type:'burst'});
    }
  }
}

