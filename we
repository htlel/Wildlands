    ctx.fillStyle='#ddd';ctx.fillRect(sx+4,sy+9,2,3);ctx.fillRect(sx+7,sy+9,2,3);ctx.fillRect(sx+e.w-7,sy+9,2,3);
  } else if(e.name==='Golem'){
    ctx.fillStyle=col2;ctx.fillRect(sx,sy+4,e.w,e.h-4);
    ctx.fillStyle=col;ctx.fillRect(sx+2,sy+2,e.w-4,e.h-4);
    ctx.fillStyle=col2;ctx.fillRect(sx+2,sy+10,e.w-4,3);ctx.fillRect(sx+2,sy+20,e.w-4,3);
    ctx.fillStyle='#ff4400';ctx.fillRect(sx+5,sy+5,5,4);ctx.fillRect(sx+e.w-10,sy+5,5,4);
    ctx.fillStyle='rgba(255,100,0,0.6)';ctx.fillRect(sx+6,sy+6,3,2);ctx.fillRect(sx+e.w-9,sy+6,3,2);
  } else if(e.name==='Scorpion'){
    ctx.fillStyle=col;ctx.fillRect(sx+2,sy+4,e.w-4,e.h-4);
    ctx.fillStyle=col2;ctx.fillRect(sx-5,sy+8,7,3);ctx.fillRect(sx+e.w-2,sy+8,7,3);
    ctx.fillRect(sx-3,sy+4,5,3);ctx.fillRect(sx+e.w-2,sy+4,5,3);
    ctx.fillStyle=col;ctx.fillRect(sx+4,sy,e.w-8,8);
    ctx.fillStyle=col2;ctx.fillRect(sx+e.w/2-1,sy-6,3,7);
    ctx.fillStyle='#ffaa00';ctx.fillRect(sx+e.w/2,sy-8,2,4);
    ctx.fillStyle='#ff4400';ctx.fillRect(sx+4,sy+3,3,3);ctx.fillRect(sx+e.w-7,sy+3,3,3);
  } else if(e.name==='FireSprite'){
    ctx.fillStyle=col2;ctx.fillRect(sx+2,sy+8,e.w-4,e.h-8);
    ctx.fillStyle=col;ctx.fillRect(sx+4,sy+4,e.w-8,e.h-4);
    ctx.fillStyle='#ffcc00';ctx.fillRect(sx+3,sy,4,8);ctx.fillRect(sx+e.w-7,sy+2,4,7);
    ctx.fillStyle='rgba(255,200,0,0.8)';ctx.fillRect(sx+4,sy+2,3,5);
    ctx.fillStyle='#fff';ctx.fillRect(sx+4,sy+6,3,3);ctx.fillRect(sx+e.w-7,sy+6,3,3);
  } else {
    ctx.fillStyle=col;ctx.fillRect(sx,sy+4,e.w,e.h-4);
    ctx.fillStyle=col2;ctx.fillRect(sx+2,sy,e.w-4,6);ctx.fillRect(sx+5,sy-4,e.w-10,5);
    ctx.fillStyle='#ff4400';ctx.fillRect(sx+3,sy+6,3,3);ctx.fillRect(sx+e.w-6,sy+6,3,3);
    ctx.fillStyle='#eee';ctx.fillRect(sx+4,sy+12,2,4);ctx.fillRect(sx+e.w-6,sy+12,2,4);
  }
  const bw=e.w+10,bh=4,bx2=sx-5,by2=sy-12;
  ctx.fillStyle='rgba(0,0,0,0.5)';ctx.fillRect(bx2,by2,bw,bh);
  const ratio=e.hp/e.maxHp;
  ctx.fillStyle=ratio>.6?'#44dd88':ratio>.3?'#ffcc44':'#ff4455';
  ctx.fillRect(bx2,by2,Math.floor(bw*ratio),bh);
  ctx.fillStyle='rgba(255,255,255,0.15)';ctx.fillRect(bx2,by2,bw,1);
}

function drawNPC(n,cx,cy){
  const sx=n.x-cx,sy=n.y-cy;
  if(sx<-60||sx>W+60||sy<-60||sy>H+60)return;
  ctx.fillStyle='rgba(0,0,0,0.15)';ctx.beginPath();ctx.ellipse(sx+n.w/2,sy+n.h+3,n.w/2+1,4,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle=n.color;ctx.fillRect(sx,sy+6,n.w,n.h-6);
  ctx.fillStyle='rgba(255,255,255,0.18)';ctx.fillRect(sx+2,sy+6,n.w-4,3);
  ctx.fillStyle='#fde68a';ctx.fillRect(sx+1,sy,n.w-2,8);
  ctx.fillStyle='#78350f';ctx.fillRect(sx+1,sy-2,n.w-2,4);
  ctx.fillStyle='#1a0a30';ctx.fillRect(sx+3,sy+2,2,2);ctx.fillRect(sx+n.w-5,sy+2,2,2);
  const px2=player.x-cx,py2=player.y-cy;
  if(Math.hypot(sx-px2,sy-py2)<160){
    ctx.fillStyle='rgba(255,255,255,0.9)';ctx.fillRect(sx-4,sy-20,32,14);ctx.fillRect(sx+6,sy-7,6,4);
    ctx.fillStyle='#1a0a30';ctx.font='8px VT323';ctx.textAlign='left';ctx.fillText('[E] TALK',sx-2,sy-10);
  }
}

function drawChest(ch,cx,cy){
  const sx=ch.x-cx,sy=ch.y-cy;
  if(sx<-40||sx>W||sy<-40||sy>H)return;
  if(ch.opened){
    ctx.fillStyle='#1e293b';ctx.fillRect(sx-10,sy-10,26,18);
    ctx.fillStyle='#0f172a';ctx.fillRect(sx-10,sy-10,26,7);
  } else {
    ctx.fillStyle='rgba(0,0,0,0.18)';ctx.fillRect(sx-8,sy+8,24,6);
    ctx.fillStyle='#7c4a14';ctx.fillRect(sx-10,sy-10,26,20);
    ctx.fillStyle='#9a6020';ctx.fillRect(sx-10,sy-10,26,9);
    ctx.fillStyle='#b8860b';ctx.fillRect(sx-10,sy-3,26,3);
    ctx.fillRect(sx-10,sy-10,3,20);ctx.fillRect(sx+13,sy-10,3,20);
    ctx.fillStyle='#fbbf24';ctx.fillRect(sx,sy-8,6,5);
    ctx.fillStyle='#f59e0b';ctx.fillRect(sx+1,sy-6,4,3);
    ctx.fillStyle='rgba(255,255,255,0.08)';ctx.fillRect(sx-9,sy-9,22,3);
  }
}

function drawMinimap(){
  const mc=document.getElementById('minimapCanvas');
  const mctx=mc.getContext('2d');
  const mw=128,mh=96,scX=mw/WW,scY=mh/WH;
  mctx.fillStyle='#000';mctx.fillRect(0,0,mw,mh);
  const biomeColors={
    [BIOME.PLAINS]:'#2d7a40',[BIOME.FOREST]:'#165530',[BIOME.DESERT]:'#c49020',
    [BIOME.VOLCANO]:'#8a2010',[BIOME.TUNDRA]:'#c0d8ec',[BIOME.SWAMP]:'#2a5020',
    [BIOME.RUINS]:'#6a5530',[BIOME.COAST]:'#1848b8',
  };
  for(let y=0;y<WH;y+=2)for(let x=0;x<WW;x+=2){
    const t=world[y]?.[x];
    if(t===T.WATER||t===T.LAVA||t===T.SHALLOW)
      mctx.fillStyle=t===T.LAVA?'#cc3010':t===T.SHALLOW?'#2060d0':'#1040b0';
    else mctx.fillStyle=biomeColors[biomeMap[y]?.[x]]||'#222';
    mctx.fillRect(x*scX,y*scY,scX*2+.5,scY*2+.5);
  }
  const ppx=player.x/TILE*scX,ppy=player.y/TILE*scY;
  mctx.fillStyle='rgba(255,255,255,0.3)';mctx.beginPath();mctx.arc(ppx,ppy,4,0,Math.PI*2);mctx.fill();
  mctx.fillStyle='#fff';mctx.beginPath();mctx.arc(ppx,ppy,2,0,Math.PI*2);mctx.fill();
}

function update(){
  if(gameState!=='playing')return;
  waterAnim++;
  let dx=0,dy=0;
  if(keys['ArrowLeft']||keys['KeyA']){dx=-player.spd;player.facing=-1}
  if(keys['ArrowRight']||keys['KeyD']){dx=player.spd;player.facing=1}
  if(keys['ArrowUp']||keys['KeyW'])dy=-player.spd;
  if(keys['ArrowDown']||keys['KeyS'])dy=player.spd;
  if(dx&&dy){dx*=.707;dy*=.707}
  if(dx||dy){player.walkStep++;player.animTimer++;if(player.animTimer>8){player.animTimer=0;player.animFrame^=1}}
  moveWith(player,dx,dy);
  player.x=Math.max(0,Math.min(WPX-player.w,player.x));
  player.y=Math.max(0,Math.min(HPX-player.h,player.y));
  if(player.attackTimer>0)player.attackTimer--;
  if(player.invincible>0)player.invincible--;
  player.mp=Math.min(player.maxMp,player.mp+.04);
  camera.x=player.x-W/2+player.w/2;camera.y=player.y-H/2+player.h/2;
  camera.x=Math.max(0,Math.min(WPX-W,camera.x));camera.y=Math.max(0,Math.min(HPX-H,camera.y));

  enemies.forEach(e=>{
    if(!e.alive)return;
    if(e.flashTimer>0)e.flashTimer--;
    const pdx=player.x-e.x,pdy=player.y-e.y,dist=Math.sqrt(pdx*pdx+pdy*pdy);
    if(dist<190)e.aggro=true;if(dist>300)e.aggro=false;
    if(e.aggro){
      const l=dist||1;moveWith(e,pdx/l*e.spd,pdy/l*e.spd);e.dir=pdx>0?1:-1;
      if(dist<20&&player.invincible===0){
        player.hp=Math.max(0,player.hp-e.dmg*.06);player.invincible=32;
        for(let i=0;i<6;i++)particles.push({x:player.x+player.w/2,y:player.y+player.h/2,vx:(Math.random()-.5)*6,vy:(Math.random()-1)*4,life:20,maxLife:20,color:'#ff5566',r:3,type:'hit'});
        if(player.hp<=0){notify('⚡ You died! Respawning...');setTimeout(()=>{player.hp=player.maxHp;player.mp=player.maxMp;player.x=85*TILE;player.y=72*TILE},1500)}
      }
    } else {
      e.timer++;if(e.timer>80){e.wvx=(Math.random()-.5)*e.spd*.6;e.wvy=(Math.random()-.5)*e.spd*.6;e.timer=0}
      moveWith(e,e.wvx,e.wvy);
    }
  });

  npcs.forEach(n=>{n.timer++;if(n.timer>140){n.wvx=(Math.random()-.5)*.5;n.timer=0}moveWith(n,n.wvx,0)});
  particles=particles.filter(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.15;p.life--;return p.life>0});
  dmgTexts2=dmgTexts2.filter(d=>{d.y+=d.vy;d.vy+=.02;d.life--;return d.life>0});

  if(notifTimer>0){notifTimer--;if(notifTimer===0){document.getElementById('notif').style.opacity='0';setTimeout(()=>{if(notifQueue.length)showNotif()},400)}}
  else if(notifQueue.length)showNotif();

  const tx=Math.floor(player.x/TILE),ty=Math.floor(player.y/TILE);
  const zone=getZone(tx,ty);
  if(zone!==currentZone){
    currentZone=zone;const zt=document.getElementById('zoneToast');
    zt.textContent=zone;zt.classList.add('show');
    document.getElementById('zoneHud').textContent='ZONE: '+zone;
    setTimeout(()=>zt.classList.remove('show'),2800);
  }

  document.getElementById('hpBar').style.width=(player.hp/player.maxHp*100)+'%';
  document.getElementById('mpBar').style.width=(player.mp/player.maxMp*100)+'%';
  document.getElementById('hpText').textContent=Math.ceil(player.hp);
  document.getElementById('mpText').textContent=Math.ceil(player.mp);
  document.getElementById('sLvl').textContent=player.lvl;
  document.getElementById('sExp').textContent=player.exp+'/'+player.expNext;
  document.getElementById('sGold').textContent=player.gold;
  document.getElementById('sKills').textContent=player.kills;
}

function draw(){
  ctx.clearRect(0,0,W,H);
  const cx=Math.floor(camera.x),cy=Math.floor(camera.y);
  const stx=Math.max(0,Math.floor(cx/TILE)),etx=Math.min(WW,stx+Math.ceil(W/TILE)+2);
  const sty=Math.max(0,Math.floor(cy/TILE)),ety=Math.min(WH,sty+Math.ceil(H/TILE)+2);
  for(let ty=sty;ty<ety;ty++)for(let tx=stx;tx<etx;tx++)drawTile(tx,ty,tx*TILE-cx,ty*TILE-cy);

  const visDecos=decorations.filter(d=>d.y-cy>-80&&d.y-cy<H+40&&d.x-cx>-60&&d.x-cx<W+60);
  visDecos.sort((a,b)=>a.y-b.y);
  visDecos.forEach(d=>{if(d.type==='rock')drawRock(d,cx,cy)});
  chests.forEach(ch=>drawChest(ch,cx,cy));
  npcs.forEach(n=>{if(n.y<player.y)drawNPC(n,cx,cy)});
  enemies.forEach(e=>{if(e.alive&&e.y<player.y)drawEnemy(e,cx,cy)});
  visDecos.forEach(d=>{if(d.type==='tree'||d.type==='dead')drawTree(d,cx,cy)});
  drawPlayer(cx,cy);
  npcs.forEach(n=>{if(n.y>=player.y)drawNPC(n,cx,cy)});
  enemies.forEach(e=>{if(e.alive&&e.y>=player.y)drawEnemy(e,cx,cy)});

  particles.forEach(p=>{
    ctx.globalAlpha=(p.life/p.maxLife)*(p.type==='spark'?.85:.7);
    ctx.fillStyle=p.color;ctx.fillRect(p.x-p.r/2,p.y-p.r/2,p.r,p.r);
  });
  ctx.globalAlpha=1;
  ctx.textAlign='center';
  dmgTexts2.forEach(d=>{
    const a=d.life/d.maxLife;
    ctx.globalAlpha=a*.7;ctx.fillStyle='rgba(0,0,0,0.8)';
    ctx.font=`bold ${14+Math.floor((1-a)*4)}px VT323`;
    ctx.fillText('-'+d.val,d.x-cx+1,d.y-cy+1);
    ctx.globalAlpha=a;ctx.fillStyle=d.color;ctx.fillText('-'+d.val,d.x-cx,d.y-cy);
  });
  ctx.globalAlpha=1;ctx.textAlign='left';

  if(dialogBox){
    const dw=360,dh=90,ddx=(W-dw)/2,ddy=H-dh-90;
    ctx.fillStyle='rgba(4,2,14,0.95)';ctx.fillRect(ddx,ddy,dw,dh);
    ctx.strokeStyle='rgba(176,106,255,0.6)';ctx.lineWidth=1.5;ctx.strokeRect(ddx,ddy,dw,dh);
    ctx.fillStyle='rgba(176,106,255,0.15)';ctx.fillRect(ddx,ddy,dw,20);
    ctx.fillStyle='#c084fc';ctx.font='13px VT323';ctx.fillText('◆ '+dialogBox.name.toUpperCase(),ddx+12,ddy+15);
    ctx.fillStyle='rgba(255,255,255,0.85)';ctx.font='18px VT323';
    const words=dialogBox.text.split(' ');let line='',lines=[];
    words.forEach(w=>{if((line+w).length>38){lines.push(line);line=w+' '}else line+=w+' '});
    lines.push(line);lines.slice(0,2).forEach((l,i)=>ctx.fillText(l,ddx+12,ddy+38+i*20));
    ctx.fillStyle='rgba(255,255,255,0.25)';ctx.font='10px VT323';ctx.fillText('[E] close',ddx+dw-58,ddy+dh-8);
    dialogBox.timer--;if(dialogBox.timer<=0)dialogBox=null;
  }

  const vig=ctx.createRadialGradient(W/2,H/2,Math.min(W,H)*.3,W/2,H/2,Math.max(W,H)*.75);
  vig.addColorStop(0,'rgba(0,0,0,0)');vig.addColorStop(1,'rgba(0,0,0,0.4)');
  ctx.fillStyle=vig;ctx.fillRect(0,0,W,H);

  const tx2=Math.floor(player.x/TILE),ty2=Math.floor(player.y/TILE);
  if(biomeMap[ty2]?.[tx2]===BIOME.VOLCANO){ctx.fillStyle='rgba(255,60,0,0.06)';ctx.fillRect(0,0,W,H)}
  else if(biomeMap[ty2]?.[tx2]===BIOME.TUNDRA){ctx.fillStyle='rgba(140,180,220,0.05)';ctx.fillRect(0,0,W,H)}

  drawMinimap();
}

function loop(){requestAnimationFrame(loop);if(gameState!=='playing')return;update();draw()}
requestAnimationFrame(loop);

function startGame(){
  document.getElementById('titleScreen').style.display='none';
  document.getElementById('hud').style.display='flex';
  document.getElementById('hotbar').style.display='flex';
  generateWorld();gameState='playing';
  notify('Welcome to Wildlands! Explore the world beyond the plains.');
}
</script>
