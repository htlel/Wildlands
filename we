function setSlot(i){activeSlot=i;document.querySelectorAll('.hotbar-slot').forEach((s,j)=>s.classList.toggle('active',j===i))}

function isSolid(tx,ty){
  if(tx<0||ty<0||tx>=WW||ty>=WH)return true;
  const t=world[ty]?.[tx];
  return t===T.WATER||t===T.STONE||t===T.LAVA||t===T.OBSIDIAN||t===T.VOID;
}
function isSolidPx(px,py){return isSolid(Math.floor(px/TILE),Math.floor(py/TILE))}
function moveWith(ent,dx,dy){
  const nx=ent.x+dx,ny=ent.y+dy;
  const hw=ent.w/2,b=ent.h-4;
  const bx=!isSolidPx(nx-hw+1,ent.y+b/2)&&!isSolidPx(nx+hw-1,ent.y+b/2)&&!isSolidPx(nx-hw+1,ent.y+ent.h-2)&&!isSolidPx(nx+hw-1,ent.y+ent.h-2);
  const by=!isSolidPx(ent.x-hw+1,ny+b/2)&&!isSolidPx(ent.x+hw-1,ny+b/2)&&!isSolidPx(ent.x-hw+1,ny+ent.h-2)&&!isSolidPx(ent.x+hw-1,ny+ent.h-2);
  if(bx)ent.x=nx;if(by)ent.y=ny;
}

function tryAttack(){
  if(player.attackTimer>0)return;
  player.attackTimer=player.attackCooldown;
  const range=44,cx=player.x+player.w/2+player.facing*range,cy=player.y+player.h/2;
  for(let i=0;i<10;i++)particles.push({x:cx+(Math.random()-.5)*20,y:cy+(Math.random()-.5)*20,vx:(Math.random()-.5)*6,vy:(Math.random()-1.5)*4,life:18,maxLife:18,color:Math.random()<.5?'#ffcc44':'#ffaa22',r:2+Math.random()*3,type:'spark'});
  enemies.forEach(e=>{
    if(!e.alive)return;
    const ex=e.x+e.w/2,ey=e.y+e.h/2;
    if(Math.abs(ex-cx)<42&&Math.abs(ey-cy)<38){
      const dmg=player.atk+Math.floor(Math.random()*10);
      e.hp-=dmg;e.flashTimer=10;
      spawnDmg(e.x+e.w/2,e.y-8,dmg,'#ffcc44');
      if(e.hp<=0){
        e.alive=false;player.exp+=e.exp;player.gold+=e.gold;player.kills++;
        checkLvl();notify(`+${e.exp} EXP  +${e.gold}G`);
        for(let i=0;i<14;i++)particles.push({x:e.x+e.w/2,y:e.y+e.h/2,vx:(Math.random()-.5)*7,vy:(Math.random()-1.5)*6,life:30,maxLife:30,color:e.color,r:3+Math.random()*4,type:'burst'});
      }
    }
  });
}

function spawnDmg(x,y,v,col='#fff'){dmgTexts2.push({x,y,vy:-1.8,life:45,maxLife:45,val:v,color:col})}

function checkLvl(){
  if(player.exp>=player.expNext){
    player.lvl++;player.exp-=player.expNext;player.expNext=Math.floor(player.expNext*1.65);
    player.maxHp+=20;player.hp=player.maxHp;player.maxMp+=10;player.mp=player.maxMp;player.atk+=5;
    notify(`⚡ LEVEL UP! Now Lv.${player.lvl}`);
    for(let i=0;i<24;i++)particles.push({x:player.x+player.w/2,y:player.y,vx:(Math.random()-.5)*9,vy:(Math.random()-2)*6,life:45,maxLife:45,color:Math.random()<.5?'#ffcc44':'#b06aff',r:4+Math.random()*4,type:'burst'});
  }
}

function tryInteract(){
  const px=player.x+player.w/2,py=player.y+player.h/2;
  for(const n of npcs){if(Math.abs(n.x+n.w/2-px)<52&&Math.abs(n.y+n.h/2-py)<52){dialogBox={name:n.name,text:n.msg,timer:240};return}}
  for(const ch of chests){
    if(!ch.opened&&Math.abs(ch.x-px)<42&&Math.abs(ch.y-py)<42){
      ch.opened=true;const g=10+Math.floor(Math.random()*60),hp=20+Math.floor(Math.random()*40);
      player.gold+=g;player.hp=Math.min(player.maxHp,player.hp+hp);
      notify(`✦ Chest! +${g}G  +${hp}HP`);
      for(let i=0;i<12;i++)particles.push({x:ch.x,y:ch.y,vx:(Math.random()-.5)*6,vy:(Math.random()-2)*5,life:35,maxLife:35,color:'#ffcc44',r:3+Math.random()*3,type:'burst'});
    }
  }
}

