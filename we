<script>
(function(){
  const c=document.getElementById('stars');
  for(let i=0;i<120;i++){
    const s=document.createElement('div');
    s.className='star';
    const sz=Math.random()<.15?2:1;
    s.style.cssText=`width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${1.5+Math.random()*3}s;animation-delay:${Math.random()*3}s`;
    c.appendChild(s);
  }
})();

const canvas=document.getElementById('gameCanvas');
const ctx=canvas.getContext('2d');
let W,H;
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
resize();window.addEventListener('resize',resize);

const TILE=32,WW=200,WH=150;
const WPX=WW*TILE,HPX=WH*TILE;

const T={VOID:0,GRASS:1,DIRT:2,WATER:3,STONE:4,SAND:5,SNOW:6,DARKGRASS:7,FLOWER:8,PATH:9,SHALLOW:10,LAVA:11,VOLCANIC:12,SWAMP:13,TUNDRA:14,OBSIDIAN:15,RIVERBED:16};

const BIOME={PLAINS:0,FOREST:1,DESERT:2,VOLCANO:3,TUNDRA:4,SWAMP:5,RUINS:6,COAST:7};

const BIOME_REGIONS=[
  {id:BIOME.PLAINS,cx:85,cy:75,rx:55,ry:45,priority:0},
  {id:BIOME.FOREST,cx:40,cy:38,rx:35,ry:30,priority:1},
  {id:BIOME.DESERT,cx:158,cy:105,rx:38,ry:35,priority:1},
  {id:BIOME.VOLCANO,cx:168,cy:30,rx:26,ry:22,priority:2},
  {id:BIOME.TUNDRA,cx:100,cy:12,rx:55,ry:22,priority:1},
  {id:BIOME.SWAMP,cx:28,cy:110,rx:30,ry:28,priority:1},
  {id:BIOME.RUINS,cx:148,cy:72,rx:22,ry:18,priority:2},
  {id:BIOME.COAST,cx:185,cy:75,rx:20,ry:60,priority:0},
];

let world=[],biomeMap=[],decorations=[],enemies=[],npcs=[],chests=[],particles=[],dmgTexts2=[];
let camera={x:0,y:0},gameState='title',dialogBox=null,activeSlot=0;
let notifQueue=[],notifTimer=0,currentZone='';
let waterAnim=0;

function hash(x,y,s){let n=Math.sin(x*127.1+y*311.7+s*43.5)*43758.5453;return n-Math.floor(n)}
function smoothNoise(x,y,s,scale){
  const fx=x/scale,fy=y/scale;
  const ix=Math.floor(fx),iy=Math.floor(fy);
  const tx=fx-ix,ty=fy-iy;
  const ux=tx*tx*(3-2*tx),uy=ty*ty*(3-2*ty);
  const a=hash(ix,iy,s),b=hash(ix+1,iy,s),c=hash(ix,iy+1,s),d=hash(ix+1,iy+1,s);
  return a+(b-a)*ux+(c-a)*uy+(d+a-b-c)*ux*uy;
}

function getBiomeAt(x,y){
  let bestBiome=BIOME.PLAINS,bestScore=-Infinity;
  for(const r of BIOME_REGIONS){
    const dx=(x-r.cx)/r.rx,dy=(y-r.cy)/r.ry;
    const dist2=dx*dx+dy*dy;
    const score=(1.0/(dist2+0.01))+r.priority*0.5;
    if(score>bestScore){bestScore=score;bestBiome=r.id}
  }
  return bestBiome;
}

function isRiver(x,y){
  const rx1=100+Math.sin(y*0.08)*12+Math.sin(y*0.03)*6;
  const dist1=Math.abs(x-rx1);
  if(y>18&&y<130&&dist1<2.5)return true;
  if(y>60&&y<75){
    const bx=95+Math.sin(y*0.15)*5+(y-60)*0.8;
    if(Math.abs(x-bx)<2&&x>96&&x<140)return true;
  }
  return false;
}

function generateWorld(){
  world=[];biomeMap=[];decorations=[];enemies=[];npcs=[];chests=[];

  for(let y=0;y<WH;y++){
    biomeMap[y]=[];
    for(let x=0;x<WW;x++) biomeMap[y][x]=getBiomeAt(x,y);
  }

  for(let y=0;y<WH;y++){
    world[y]=[];
    for(let x=0;x<WW;x++){
      const biome=biomeMap[y][x];
      const detail=smoothNoise(x,y,7,3);
      const micro=smoothNoise(x,y,13,1.5);

      if(isRiver(x,y)){world[y][x]=T.WATER;continue}
      const rx1=100+Math.sin(y*0.08)*12+Math.sin(y*0.03)*6;
      if(y>18&&y<130&&Math.abs(x-rx1)<4.5&&Math.abs(x-rx1)>=2.5){world[y][x]=T.SHALLOW;continue}

      let tile;
      switch(biome){
        case BIOME.PLAINS:
          if(detail<0.12)tile=T.DIRT;
          else if(detail>0.85&&micro>0.5)tile=T.FLOWER;
          else tile=T.GRASS;
          break;
        case BIOME.FOREST:
          if(detail<0.08)tile=T.SHALLOW;
          else if(detail<0.18)tile=T.DIRT;
          else tile=T.DARKGRASS;
          break;
        case BIOME.DESERT:
          if(detail>0.78)tile=T.STONE;
          else tile=T.SAND;
          break;
        case BIOME.VOLCANO:
          {const dx=(x-168)/26,dy=(y-30)/22,d2=dx*dx+dy*dy;
          if(d2<0.12)tile=T.LAVA;
          else if(d2<0.25)tile=T.OBSIDIAN;
          else if(detail>0.65)tile=T.VOLCANIC;
          else tile=T.STONE;}
          break;
        case BIOME.TUNDRA:
          if(detail<0.15)tile=T.STONE;
          else if(detail<0.22)tile=T.SHALLOW;
          else tile=T.SNOW;
          break;
        case BIOME.SWAMP:
          if(detail<0.3)tile=T.WATER;
          else if(detail<0.45)tile=T.SHALLOW;
          else tile=T.SWAMP;
          break;
        case BIOME.RUINS:
          if(detail<0.35)tile=T.PATH;
          else if(detail>0.72)tile=T.STONE;
          else tile=T.DIRT;
          break;
        case BIOME.COAST:
          {const distCoast=WW-x;
          if(distCoast<4)tile=T.WATER;
          else if(distCoast<8)tile=T.SHALLOW;
          else tile=T.SAND;}
          break;
        default: tile=T.GRASS;
      }
      world[y][x]=tile;
    }
  }

  const villages=[
    {x:85,y:72,name:'Greenfield'},{x:42,y:40,name:'Thornwood'},
    {x:155,y:108,name:'Sandkeep'},{x:100,y:10,name:'Frostholm'},
    {x:30,y:112,name:'Bogmere'},{x:148,y:68,name:'Old Sanctum'},
  ];
  villages.forEach((v,vi)=>{
    for(let dy=-5;dy<=5;dy++)for(let dx=-5;dx<=5;dx++){
      const tx=v.x+dx,ty=v.y+dy;
      if(tx>0&&tx<WW-1&&ty>0&&ty<WH-1){
        const tile=world[ty][tx];
        if(tile===T.WATER||tile===T.LAVA)continue;
        if(Math.abs(dx)<=1||Math.abs(dy)<=1)world[ty][tx]=T.PATH;
        else if(tile!==T.PATH)world[ty][tx]=T.DIRT;
      }
    }
    const nNames=['Merchant','Elder','Guard','Traveler','Herbalist','Sage'];
    const nMsgs=['Fine goods from afar!','The river flows from frozen lands...','Desert raiders grow bolder.','The volcano stirs at night.','Swamp herbs heal deep wounds.','The ruins hold forgotten power.'];
    npcs.push({x:(v.x+2)*TILE,y:(v.y-1)*TILE,w:14,h:22,color:'#60a5fa',name:nNames[vi],msg:nMsgs[vi],dir:1,timer:0,wvx:0});
  });

  const treeClusters=[];
  for(let y=2;y<WH-2;y+=8)for(let x=2;x<WW-2;x+=8){
    const b=biomeMap[y]?.[x];
    if(b===BIOME.FOREST&&Math.random()<0.72)treeClusters.push({x,y,r:6+Math.random()*5,dense:true});
    else if(b===BIOME.PLAINS&&Math.random()<0.25)treeClusters.push({x,y,r:3+Math.random()*4,dense:false});
    else if(b===BIOME.SWAMP&&Math.random()<0.4)treeClusters.push({x,y,r:2+Math.random()*3,dense:false,type:'dead'});
  }
  const treeSet=new Set();
  treeClusters.forEach(cl=>{
    const count=cl.dense?Math.floor(8+Math.random()*10):Math.floor(2+Math.random()*5);
    for(let i=0;i<count;i++){
      const ang=Math.random()*Math.PI*2,dist=Math.random()*cl.r;
      const tx=Math.round(cl.x+Math.cos(ang)*dist),ty=Math.round(cl.y+Math.sin(ang)*dist);
      if(tx<1||ty<1||tx>WW-2||ty>WH-2)continue;
      const tile=world[ty]?.[tx];
      if(tile===T.WATER||tile===T.LAVA||tile===T.SHALLOW||tile===T.PATH)continue;
      const key=`${tx},${ty}`;
      if(treeSet.has(key))continue;
      treeSet.add(key);
      decorations.push({type:cl.type||'tree',x:tx*TILE,y:ty*TILE,variant:Math.floor(Math.random()*3),scale:.85+Math.random()*.3});
    }
  });

  for(let y=2;y<WH-2;y+=3)for(let x=2;x<WW-2;x+=3){
    const b=biomeMap[y]?.[x];
    const t=world[y]?.[x];
    if((b===BIOME.VOLCANO||b===BIOME.TUNDRA||b===BIOME.RUINS)&&t===T.STONE&&Math.random()<0.3)
      decorations.push({type:'rock',x:x*TILE+4,y:y*TILE+4,r:4+Math.random()*8,biome:b});
  }

  const ENEMY_SETS={
    [BIOME.PLAINS]:[{name:'Slime',color:'#33dd66',color2:'#22aa44',hp:20,dmg:5,exp:10,gold:3,w:20,h:16,spd:.6},{name:'Goblin',color:'#88cc22',color2:'#557711',hp:35,dmg:12,exp:20,gold:8,w:18,h:24,spd:.8}],
    [BIOME.FOREST]:[{name:'Wolf',color:'#aabbcc',color2:'#778899',hp:45,dmg:18,exp:30,gold:5,w:22,h:18,spd:1.3},{name:'Bat',color:'#cc88ff',color2:'#9933cc',hp:12,dmg:8,exp:8,gold:2,w:18,h:14,spd:1.1}],
    [BIOME.DESERT]:[{name:'Scorpion',color:'#cc8833',color2:'#996622',hp:40,dmg:15,exp:25,gold:6,w:20,h:16,spd:.9},{name:'Goblin',color:'#c8a44a',color2:'#9a7a30',hp:35,dmg:12,exp:20,gold:8,w:18,h:24,spd:.8}],
    [BIOME.VOLCANO]:[{name:'FireSprite',color:'#ff6633',color2:'#cc3300',hp:55,dmg:25,exp:45,gold:15,w:18,h:22,spd:1.0},{name:'Golem',color:'#885533',color2:'#553322',hp:120,dmg:35,exp:80,gold:30,w:26,h:28,spd:.4}],
    [BIOME.TUNDRA]:[{name:'IceWolf',color:'#aaddff',color2:'#88bbdd',hp:60,dmg:22,exp:40,gold:10,w:22,h:18,spd:1.2},{name:'Skeleton',color:'#ddeeff',color2:'#aabbcc',hp:60,dmg:22,exp:40,gold:12,w:16,h:28,spd:.7}],
    [BIOME.SWAMP]:[{name:'Slime',color:'#557733',color2:'#334422',hp:25,dmg:8,exp:12,gold:4,w:20,h:16,spd:.5},{name:'Bat',color:'#668844',color2:'#445533',hp:15,dmg:10,exp:10,gold:3,w:18,h:14,spd:1.0}],
    [BIOME.RUINS]:[{name:'Skeleton',color:'#ddeeff',color2:'#aabbcc',hp:60,dmg:22,exp:40,gold:12,w:16,h:28,spd:.7},{name:'Golem',color:'#7a8899',color2:'#556677',hp:100,dmg:28,exp:70,gold:25,w:26,h:28,spd:.35}],
    [BIOME.COAST]:[{name:'Slime',color:'#33aadd',color2:'#2288bb',hp:18,dmg:6,exp:8,gold:2,w:20,h:16,spd:.7}],
  };
  BIOME_REGIONS.forEach(region=>{
    const eset=ENEMY_SETS[region.id]||ENEMY_SETS[BIOME.PLAINS];
    const count=Math.floor((region.rx*region.ry*4)/120);
    for(let i=0;i<count;i++){
      let ex,ey,tries=0;
      do{
        const ang=Math.random()*Math.PI*2,r=Math.random();
        ex=Math.round(region.cx+Math.cos(ang)*region.rx*r);
        ey=Math.round(region.cy+Math.sin(ang)*region.ry*r);
        tries++;
      }while(tries<20&&(ex<1||ey<1||ex>=WW-1||ey>=WH-1||world[ey]?.[ex]===T.WATER||world[ey]?.[ex]===T.LAVA||world[ey]?.[ex]===T.VOID));
      if(tries>=20)continue;
      const t={...eset[Math.floor(Math.random()*eset.length)]};
      enemies.push({...t,x:ex*TILE,y:ey*TILE,maxHp:t.hp,alive:true,aggro:false,dir:1,flashTimer:0,wvx:0,wvy:0,timer:Math.floor(Math.random()*120)});
    }
  });

  for(let i=0;i<35;i++){
    let cx,cy,tries=0;
    do{cx=1+Math.floor(Math.random()*(WW-2));cy=1+Math.floor(Math.random()*(WH-2));tries++;}
    while(tries<30&&(world[cy]?.[cx]===T.WATER||world[cy]?.[cx]===T.LAVA||world[cy]?.[cx]===T.VOID));
    chests.push({x:cx*TILE+8,y:cy*TILE+8,opened:false});
  }
}

