function drawTile(tx,ty,sx,sy){
  const t=world[ty]?.[tx]??T.VOID;
  const pal=TPAL[t]||TPAL[T.VOID];
  ctx.fillStyle=pal[0];ctx.fillRect(sx,sy,TILE,TILE);
  if(t===T.WATER||t===T.SHALLOW||t===T.LAVA){
    const woff=(waterAnim*0.6+(t===T.LAVA?waterAnim*0.4:0)+tx*2+ty*4)%TILE;
    ctx.fillStyle=t===T.LAVA?'rgba(255,120,0,0.3)':'rgba(100,160,255,0.2)';
    ctx.fillRect(sx,sy+(woff%10),TILE,3);ctx.fillRect(sx,sy+((woff+14)%TILE),TILE,2);
  } else if(t===T.GRASS){
    ctx.fillStyle=pal[1];ctx.fillRect(sx,sy+10,TILE,2);ctx.fillRect(sx,sy+22,TILE,2);
    ctx.fillStyle=pal[2];ctx.fillRect(sx,sy+4,TILE,1);ctx.fillRect(sx,sy+16,TILE,1);ctx.fillRect(sx,sy+28,TILE,1);
  } else if(t===T.DARKGRASS){
    ctx.fillStyle=pal[1];ctx.fillRect(sx,sy+8,TILE,2);ctx.fillRect(sx,sy+20,TILE,2);
    ctx.fillStyle=pal[2];ctx.fillRect(sx,sy+2,TILE,1);ctx.fillRect(sx,sy+14,TILE,1);
  } else if(t===T.SAND){
    ctx.fillStyle=pal[1];ctx.fillRect(sx,sy+7,TILE,2);ctx.fillRect(sx,sy+19,TILE,2);
    ctx.fillStyle=pal[2];ctx.fillRect(sx+((tx*5)%8),sy+13,TILE-((tx*5)%8),1);
  } else if(t===T.STONE||t===T.VOLCANIC||t===T.OBSIDIAN){
    ctx.fillStyle=pal[1];ctx.fillRect(sx+2,sy+TILE/2,TILE-4,1);ctx.fillRect(sx+TILE/2,sy+2,1,TILE-4);
    ctx.fillStyle=pal[2];ctx.fillRect(sx+1,sy+1,TILE/2-1,TILE/2-1);
  } else if(t===T.SNOW||t===T.TUNDRA){
    ctx.fillStyle=pal[2];ctx.fillRect(sx,sy,TILE,4);
    ctx.fillStyle=pal[1];ctx.fillRect(sx,sy+12,TILE,3);ctx.fillRect(sx,sy+24,TILE,3);
  } else if(t===T.PATH){
    ctx.fillStyle=pal[1];ctx.fillRect(sx+2,sy+2,TILE-4,TILE-4);
    ctx.fillStyle=pal[2];ctx.fillRect(sx+4,sy+4,6,4);ctx.fillRect(sx+18,sy+18,8,4);
  } else if(t===T.DIRT){
    ctx.fillStyle=pal[1];ctx.fillRect(sx+4,sy+4,TILE-8,TILE-8);
    ctx.fillStyle=pal[2];ctx.fillRect(sx+8,sy+12,8,6);
  } else if(t===T.SWAMP){
    ctx.fillStyle=pal[1];ctx.fillRect(sx,sy+8,TILE,2);ctx.fillRect(sx,sy+20,TILE,2);
    ctx.fillStyle='rgba(0,0,0,0.15)';ctx.fillRect(sx+((tx*7)%16),sy+((ty*5)%14),8,6);
  }
  if(t===T.FLOWER){
    const s2=tx*17+ty*11;
    ctx.fillStyle=['#ff6688','#ffcc44','#ff88dd','#88ddff','#ffaa44'][s2%5];
    ctx.fillRect(sx+((s2*3)%22)+4,sy+((s2*7)%22)+4,4,4);
    ctx.fillStyle='#ffee88';ctx.fillRect(sx+((s2*3)%22)+5,sy+((s2*7)%22)+5,2,2);
  }
  if(t===T.LAVA){ctx.fillStyle='rgba(255,100,0,0.08)';ctx.fillRect(sx,sy,TILE,TILE)}
  ctx.fillStyle='rgba(0,0,0,0.04)';ctx.fillRect(sx,sy,TILE,1);ctx.fillRect(sx,sy,1,TILE);
}

function drawTree(d,cx,cy){
  const sx=d.x-cx,sy=d.y-cy;
  if(sx<-60||sx>W+60||sy<-80||sy>H+40)return;
  const sc=d.scale||1,tw=Math.floor(30*sc),th=Math.floor(34*sc);
  const tx2=sx+(16-tw/2),ty2=sy-th+24;
  ctx.fillStyle='rgba(0,0,0,0.15)';
  ctx.beginPath();ctx.ellipse(sx+14,sy+26,tw/2,5,0,0,Math.PI*2);ctx.fill();
  const trunkW=Math.floor(7*sc),trunkH=Math.floor(13*sc),trunkX=sx+(16-trunkW/2);
  if(d.type==='dead'){
    ctx.fillStyle='#3a2a1a';ctx.fillRect(trunkX,sy+8,trunkW,trunkH+4);
    ctx.fillStyle='#2a1e10';ctx.fillRect(trunkX-4,sy+12,5,4);ctx.fillRect(trunkX+trunkW-1,sy+16,5,3);
  } else {
    ctx.fillStyle='#4a3016';ctx.fillRect(trunkX,sy+14,trunkW,trunkH);
    ctx.fillStyle='#5e3e20';ctx.fillRect(trunkX+1,sy+14,2,trunkH);
    const greens=[['#1a6e30','#22883c','#2da050'],['#135820','#1a6e28','#228036'],['#0e4e1a','#186028','#207232']];
    const g=greens[(d.variant||0)%3];
    ctx.fillStyle=g[0];ctx.fillRect(tx2-4,ty2+th/2,tw+8,th/2);
    ctx.fillStyle=g[1];ctx.fillRect(tx2,ty2+th/4,tw,th*3/4);
    ctx.fillStyle=g[2];ctx.fillRect(tx2+4,ty2,tw-8,th/2);
    ctx.fillStyle='rgba(255,255,255,0.06)';ctx.fillRect(tx2+2,ty2+2,4,th/3);
  }
}

function drawRock(d,cx,cy){
  const sx=d.x-cx,sy=d.y-cy;
  if(sx<-30||sx>W||sy<-30||sy>H)return;
  const r=d.r||6;
  ctx.fillStyle='rgba(0,0,0,0.12)';
  ctx.beginPath();ctx.ellipse(sx+2,sy+r+2,r+2,r*.6,0,0,Math.PI*2);ctx.fill();
  const col=d.biome===BIOME.VOLCANO?'#6a4040':d.biome===BIOME.TUNDRA?'#788898':'#555e6a';
  const col2=d.biome===BIOME.VOLCANO?'#7a5050':d.biome===BIOME.TUNDRA?'#8898a8':'#6b7585';
  ctx.fillStyle=col;ctx.beginPath();ctx.ellipse(sx,sy,r,r*.75,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle=col2;ctx.beginPath();ctx.ellipse(sx-r*.2,sy-r*.2,r*.55,r*.4,-.3,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,255,255,0.08)';ctx.beginPath();ctx.ellipse(sx-r*.25,sy-r*.2,r*.2,r*.15,-.5,0,Math.PI*2);ctx.fill();
}

function drawPlayer(cx,cy){
  const sx=player.x-cx,sy=player.y-cy;
  if(player.invincible>0&&Math.floor(player.invincible/3)%2===0)return;
  const f=player.facing;
